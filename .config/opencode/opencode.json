{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "provider": {
    "google": {
      "options": {
        "projectId": "gen-lang-client-0826591889"
      },
      "models": {
        "gemini-2.5-flash": {
          "options": {
            "thinkingConfig": {
              "thinkingBudget": 8192,
              "includeThoughts": true
            }
          }
        },
        "gemini-2.5-pro": {
          "options": {
            "thinkingConfig": {
              "thinkingBudget": 8192,
              "includeThoughts": true
            }
          }
        },
        "gemini-3-flash-preview": {
          "options": {
            "thinkingConfig": {
              "thinkingLevel": "high",
              "includeThoughts": true
            }
          }
        },
        "gemini-3-pro-preview": {
          "options": {
            "thinkingConfig": {
              "thinkingLevel": "high",
              "includeThoughts": true
            }
          }
        }
      }
    },
    "devgo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DevGo-9Router",
      "options": {
        "baseURL": "https://9router.tools.devgovietnam.io.vn/v2"
      },
      "models": {
        "DevGOVietnam-Frontier": {
          "name": "Fr-Gpt5.5-Op4.6"
        },
        "DevGOVietnam-Elite": {
          "name": "E-G5.3+So4.6"
        },
        "DevGOVietnam-Core": {
          "name": "Core free"
        },
        "ag/gemini-3.1-pro-high": {
          "name": "dg-ag/gem-3.1-pro-high"
        },
        "ag/claude-opus-4-6-thinking": {
          "name": "dg-ag/cl-Op 4.6 think"
        },
        "cx/gpt-5.5": {
          "name": "dg-cx/gpt-5.5"
        }
      }
    },
    "agentrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AgentRouter",
      "options": {
        "baseURL": "https://agentrouter.org/v1",
        "apiKey": "{env:AGENT_ROUTER}"
      },
      "models": {
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5"
        },
        "gpt-5": {
          "name": "GPT-5"
        },
        "deepseek-chat": {
          "name": "DeepSeek V3"
        }
      }
    }
  }
}